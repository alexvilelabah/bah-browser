{
  "name": "bah-browser",
  "version": "1.1.4",
  "description": "AI-powered browser agent — navigate and manipulate the web with natural language",
  "author": {
    "name": "Alex Vilela",
    "email": "alexmachadovilela@gmail.com",
    "url": "https://github.com/alexvilelabah"
  },
  "license": "PolyForm-Small-Business-1.0.0",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.main.json && electron .",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build": "npm run build:renderer && npm run build:main",
    "start": "npm run build && electron .",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:live": "npm run build && playwright test --grep \"live agent\"",
    "agent:test": "node tools/claude-test.mjs",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@ghostery/adblocker-electron": "^2.5.2",
    "cross-fetch": "^4.1.0",
    "electron-updater": "^6.8.9",
    "tesseract.js": "^7.0.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@electron/fuses": "^2.1.2",
    "@playwright/test": "^1.60.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.1.0",
    "electron": "^42.4.1",
    "electron-builder": "^25.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
